# Server
PORT=3000
PUBLIC_URL=http://localhost:3000
NODE_ENV=development

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# Database (optional - defaults to ./data/)
DATA_DIR=

# Gmail (for sending verification + reset emails)
GMAIL_USER=you@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=Spider Hub <you@gmail.com>

# Admin dashboard (https://yoursite.com/admin.html)
ADMIN_KEY=choose-a-strong-secret-password-here
